# 對外服務 Port（預設 8000）
PORT=8787

# Hugging Face Token（語者分離 + 聲紋比對必要）
# 申請：https://huggingface.co/settings/tokens
# 需接受使用條款：
#   https://huggingface.co/pyannote/speaker-diarization-community-1
#   https://huggingface.co/pyannote/embedding
HF_TOKEN=hf_IIQwh*************************AZYD

# 單檔上傳大小限制（MB，預設 500）
MAX_FILE_MB=500

# 工作保留時間（小時，超過後下次啟動時自動清理，預設 48）
JOB_TTL_HOURS=48

# 單一轉錄任務最多可以執行多久 (秒數，worker 跑 subprocess 時超過這個秒數會把該 job 標成 failed，預設21600)
JOB_TIMEOUT_SECONDS=10800

# 聲紋比對閾值（cosine similarity，0-1，預設 0.75）
# 調低（如 0.65）可提高召回率但可能誤判；調高（如 0.85）則更嚴格
SPEAKER_SIMILARITY_THRESHOLD=0.35

# 每次 POST /transcribe 可傳入的 terms 專有名詞數量上限
MAX_TERMS=30

